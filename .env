# ============================================================
# MEDIFLOW BACKEND - ENVIRONMENT VARIABLES
# Sao chép file này thành .env và điền thông tin thực tế
# ============================================================

# ---- SERVER ----
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ---- SQL SERVER DATABASE ----
DB_SERVER=DESKTOP-1JQFEUE
DB_INSTANCE=SQLEXPRESS
DB_DATABASE=MediFlowDB
DB_USERNAME=cuong
DB_PASSWORD=123456
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true


# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- BCRYPT ----
BCRYPT_ROUNDS=12

# ---- NODEMAILER (Gmail) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM_NAME=MediFlow Healthcare
MAIL_FROM_EMAIL=noreply@mediflow.com

# ---- FILE UPLOAD (MULTER) ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ---- CORS ----
FRONTEND_URL=http://localhost:3000

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- NODE-CRON (Nhắc lịch: chạy lúc 8h sáng mỗi ngày) ----
REMINDER_CRON_SCHEDULE=0 8 * * *
REMINDER_HOURS_BEFORE=24

# ---- LOGGING ----
LOG_LEVEL=debug
LOG_DIR=./logs
